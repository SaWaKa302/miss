    { place:'Kaji Bridge', lat:36.1450, lng:137.2581, episode:'Multiple Episodes', time:'Evening', desc:'A bridge area strongly associated with the calm and reflective atmosphere of Hyouka. The river and old town scenery become especially beautiful during sunset.', access:'About 10 minutes on foot from Takayama Station' },
    { place:'Takayama City Library', lat:36.1439, lng:137.2528, episode:'Investigation Scenes', time:'Afternoon', desc:'A quiet location reminiscent of the research and mystery-solving scenes from the series. The peaceful atmosphere matches the tone of Hyouka perfectly.', access:'About 5 minutes on foot from Takayama Station' },
    { place:'Hida Kokubun-ji Temple', lat:36.1444, lng:137.2547, episode:'Background Scenes', time:'Morning', desc:'A historic temple area near several recognizable scenery locations. The traditional atmosphere fits the cultural mood of the anime.', access:'About 6 minutes on foot from Takayama Station' },
