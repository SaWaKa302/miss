    { place:'Takayama Festival Floats Exhibition Hall', lat:36.1480, lng:137.2610, episode:'Cultural Scenes', time:'Noon', desc:"A cultural landmark showcasing Takayama's famous festival traditions. Fans interested in the cultural background of Hyouka may enjoy this location.", access:'About 16 minutes on foot from Takayama Station' },
