  const btn=document.getElementById('pilStartBtn');
  if(pilRouteMode==='suggest'){document.getElementById('pilBannerText').textContent=`${pilAnime} - Choose your style`;btn.style.display='none';}
  else{btn.style.display='flex';if(assigned===0){document.getElementById('pilBannerText').textContent='Click pins to set the order';btn.disabled=true;}else{document.getElementById('pilBannerText').textContent=`${assigned}/${total} spots set`;btn.disabled=false;btn.innerHTML=`<i class="ti ti-route"></i>${assigned} spots - Start`;}}
}
function setPilRouteMode(mode){
  pilRouteMode=mode;
  document.querySelectorAll('.pil-mode-card').forEach(c=>c.classList.remove('selected'));
  document.querySelectorAll(`.pil-mode-card[data-mode="${mode}"]`).forEach(c=>c.classList.add('selected'));
  renderListSheetBody();updateBanner();
}
function renderListSheetBody(){
  const ap=pins.filter(p=>p.anime===pilAnime),container=document.getElementById('pilSheetBody');if(!container)return;
  if(pilRouteMode==='suggest'){container.innerHTML='<div style="padding:16px;"><button class="wizard-use-btn" style="background:var(--green);" onclick="openWizardModal()">&#x2728; Pilgrimage Guide</button></div>';}
  else{container.innerHTML=ap.map(p=>{const color=getColor(p.anime),num=pilOrder[p.id];return `<div class="near-item" onclick="openDetail('${p.id}')"><div class="order-badge${num?' assigned':''}" style="${num?`background:${color}`:''}"> ${num||'&mdash;'}</div><div class="near-left"><div class="near-place">${pl(p)}</div><div class="near-ep">${ep(p)}</div></div><div class="near-right"><span class="detail-btn-sm"><i class="ti ti-chevron-right"></i>Detail</span></div></div>`;}).join('');}
}
function renderListSheet(){
  const total=pins.filter(p=>p.anime===pilAnime).length,assigned=Object.keys(pilOrder).length;
  document.getElementById('sheetCount').textContent=`${assigned}/${total} spots`;
  document.getElementById('sheetContent').innerHTML=`<div class="pil-mode-select"><div class="pil-mode-title">Choose your style</div><div class="pil-mode-cards"><div class="pil-mode-card${pilRouteMode==='suggest'?' selected':''}" data-mode="suggest" onclick="setPilRouteMode('suggest')"><div class="pil-mode-card-icon">&#x2728;</div><div class="pil-mode-card-label">Pilgrimage Guide</div><div class="pil-mode-card-desc">Auto-suggest route based on Q&A</div></div><div class="pil-mode-card${pilRouteMode==='manual'?' selected':''}" data-mode="manual" onclick="setPilRouteMode('manual')"><div class="pil-mode-card-icon">&#x1F5FA;</div><div class="pil-mode-card-label">Plan yourself</div><div class="pil-mode-card-desc">Tap pins to set your own order</div></div></div></div><div style="height:1px;background:var(--border);"></div><div id="pilSheetBody"></div>`;
  renderListSheetBody();
}
function startPilgrimage(){
  if(!Object.keys(pilOrder).length)return;
  pilActive=true;document.getElementById('pilStartBtn').style.display='none';
  document.getElementById('pilBannerText').textContent=`${pilAnime} - Click pins for details`;
  document.getElementById('pilHud').classList.add('visible');
  document.getElementById('sheetTitle').textContent=pilAnime;
  sheetOpen=true;document.getElementById('sheetContent').classList.remove('collapsed');
  updatePilHud();renderPilList();drawRoute();
  const first=getOrderedPins()[0];if(first)map.flyTo([first.lat,first.lng],14,{animate:true,duration:1});
}
function adjustSheet(){
  const hud=document.getElementById('pilHud'),sheet=document.getElementById('listSheet');
  if(pilActive&&hud.classList.contains('visible')){requestAnimationFrame(()=>{sheet.style.bottom=hud.offsetHeight+'px';document.getElementById('sheetContent').style.maxHeight='180px';});}
  else{sheet.style.bottom='0';document.getElementById('sheetContent').style.maxHeight='50vh';}
}
function getOrderedPins(){return Object.entries(pilOrder).sort((a,b)=>a[1]-b[1]).map(([id])=>pins.find(p=>String(p.id)===String(id))).filter(Boolean);}
function updatePilHud(){
  const ordered=getOrderedPins(),nextPin=ordered.find(p=>!pilDone[p.id]);
  const done=ordered.filter(p=>pilDone[p.id]).length,total=ordered.length;
  const card=document.getElementById('pilNextCard');
  if(!nextPin){card.innerHTML=`<div style="text-align:center;padding:8px 0;"><div style="font-size:24px;margin-bottom:6px;">&#x1F389;</div><div style="font-size:16px;font-weight:700;color:#111;margin-bottom:4px;">Complete!</div><div style="font-size:13px;color:#888;margin-bottom:12px;">${total} spots conquered</div><button onclick="openAppReview()" style="margin-bottom:8px;padding:10px;border-radius:99px;background:#5865F2;color:#fff;border:none;font-size:13px;cursor:pointer;font-weight:500;width:100%;">Rate this app</button><button onclick="exitPilMode()" style="padding:10px;border-radius:99px;background:#1D9E75;color:#fff;border:none;font-size:14px;cursor:pointer;font-weight:500;width:100%;">Finish</button></div>`;return;}
  const url=`https://www.google.com/maps/dir/?api=1&destination=${nextPin.lat},${nextPin.lng}&travelmode=walking`;
  const distStr=userLat!==null?`${fmtDist(dist(userLat,userLng,nextPin.lat,nextPin.lng))} &middot; ${walkMin(dist(userLat,userLng,nextPin.lat,nextPin.lng))}`:'Location not available';
  card.innerHTML=`<div class="pil-progress"><div class="pil-progress-bar"><div class="pil-progress-fill" style="width:${done/total*100}%"></div></div><span class="pil-progress-text">${done}/${total} spots</span></div><div class="pil-next-label">Next &mdash; #${pilOrder[nextPin.id]}</div><div class="pil-next-place">${pl(nextPin)}</div><div class="pil-next-meta"><span>${ep(nextPin)}</span><span>${distStr}</span></div><div class="pil-next-actions"><a class="pil-nav-big" href="${url}" target="_blank"><i class="ti ti-navigation"></i>Open in Google Maps</a><button class="pil-arrived-btn" onclick="markArrived('${nextPin.id}')"><i class="ti ti-check"></i>Arrived!</button></div>`;
  requestAnimationFrame(adjustSheet);
}
function markArrived(id){pilDone[id]=true;refreshMarkers();updatePilHud();renderPilList();drawRoute();if(detailOpenId===id)closeDetail();const next=getOrderedPins().find(p=>!pilDone[p.id]);if(next)map.flyTo([next.lat,next.lng],14,{animate:true,duration:1});}
function drawRoute(){if(pilRouteLayer){map.removeLayer(pilRouteLayer);pilRouteLayer=null;}const o=getOrderedPins();if(o.length<2)return;pilRouteLayer=L.polyline(o.map(p=>[p.lat,p.lng]),{color:'#1D9E75',weight:3,opacity:.7,dashArray:'8 6'}).addTo(map);}
function renderPilList(){
  const cont=document.getElementById('sheetContent'),ordered=getOrderedPins();
  document.getElementById('sheetCount').textContent=`${ordered.length} spots`;
  cont.innerHTML=ordered.map(p=>{
    const color=getColor(p.anime),done=pilDone[p.id],num=pilOrder[p.id];
    const d=userLat!==null?dist(userLat,userLng,p.lat,p.lng):null;
    const url=`https://www.google.com/maps/dir/?api=1&destination=${p.lat},${p.lng}&travelmode=walking`;
    return `<div class="pil-item${done?' done':''}" onclick="openDetail('${p.id}')"><div class="pil-num" style="background:${done?'#bbb':color}">${done?'&#x2713;':num}</div><div class="pil-info"><div class="pil-place" style="${done?'text-decoration:line-through;color:#aaa;':''}">${pl(p)}</div><div class="pil-sub">${ep(p)}${d!==null?' &middot; '+fmtDist(d):''}</div></div><div class="pil-right" onclick="event.stopPropagation()">${done?'<span class="pil-done-badge">Visited</span>':`<a class="pil-nav-btn" href="${url}" target="_blank"><i class="ti ti-navigation"></i>Navigate</a>`}</div></div>`;
  }).join('');
}
function exitPilMode(){
  pilMode=false;pilActive=false;pilAnime='';pilOrder={};pilDone={};pilNextOrder=1;
  if(pilRouteLayer){map.removeLayer(pilRouteLayer);pilRouteLayer=null;}
  document.getElementById('pilControls').style.display='none';document.getElementById('pilHud').classList.remove('visible');
  document.getElementById('pilStartBtn').style.display='none';document.getElementById('sheetTitle').textContent='Spot List';
  document.getElementById('listSheet').style.bottom='0';document.getElementById('sheetContent').style.maxHeight='50vh';
  selectedAnime='';document.getElementById('pillLabel').textContent='Select Anime';document.getElementById('pillLabel').classList.remove('chosen');
  closeDetail();refreshMarkers();applyFilter();
}

// ── Dropdown ──────────────────────────────────────
function toggleDD(e){if(pilMode)return;e.stopPropagation();ddOpen=!ddOpen;document.getElementById('animePill').classList.toggle('open',ddOpen);document.getElementById('animeDD').classList.toggle('open',ddOpen);if(ddOpen){document.getElementById('ddInput').value='';renderDDItems('');setTimeout(()=>document.getElementById('ddInput').focus(),50);}}
function renderDDItems(q){
  const all=[...new Set(pins.map(p=>p.anime))],f=q?all.filter(a=>a.toLowerCase().includes(q.toLowerCase())):all;
  const el=document.getElementById('ddItems');
  if(!f.length){el.innerHTML='<div style="padding:12px;font-size:14px;color:#999;text-align:center;">Not found</div>';return;}
  el.innerHTML=f.map(a=>{
    const color=getColor(a),cnt=pins.filter(p=>p.anime===a).length;
    const esc=a.replace(/\\/g,'\\\\').replace(/'/g,"\\'");
    return `<div class="dd-item${a===selectedAnime?' sel':''}" onclick="onAnimeSelect('${esc}')"><span class="dd-dot" style="background:${color}"></span><span style="flex:1">${a}</span><span class="dd-cnt">${cnt}</span></div>`;
  }).join('');
}
function onAnimeSelect(anime){document.getElementById('animePill').classList.remove('open');document.getElementById('animeDD').classList.remove('open');ddOpen=false;enterAssignMode(anime);}
function selectAnime(anime){selectedAnime=anime;document.getElementById('pillLabel').textContent=anime||'Select Anime';document.getElementById('pillLabel').classList.toggle('chosen',!!anime);document.getElementById('animePill').classList.remove('open');document.getElementById('animeDD').classList.remove('open');ddOpen=false;applyFilter();}

// ── Filter ────────────────────────────────────────
function applyFilter(){
  if(pilMode)return;
  const q=document.getElementById('placeSearch').value.toLowerCase();
  let filtered=pins.filter(p=>(!selectedAnime||p.anime===selectedAnime)&&(!q||pl(p).toLowerCase().includes(q)||p.anime.toLowerCase().includes(q)));
  if(userLat!==null)filtered=filtered.map(p=>({...p,_d:dist(userLat,userLng,p.lat,p.lng)})).sort((a,b)=>a._d-b._d);
  markers.forEach(({pin,marker})=>{const show=!!filtered.find(f=>f.id===pin.id);if(show)map.addLayer(marker);else map.removeLayer(marker);marker.setIcon(makeIcon(getColor(pin.anime),null,false));});
  document.getElementById('sheetTitle').textContent=userLat!==null?'Nearby Spots':'Spot List';
  document.getElementById('sheetCount').textContent=`${filtered.length} spots`;
  const cont=document.getElementById('sheetContent');
  if(!filtered.length){cont.innerHTML='<div class="empty-sheet">No spots found</div>';return;}
  cont.innerHTML=filtered.map(p=>{const color=getColor(p.anime),d=p._d,near=d!==undefined&&d<3000;return `<div class="near-item" onclick="openDetail('${p.id}')"><div class="near-left"><div class="near-anime"><span style="width:8px;height:8px;border-radius:50%;background:${color};display:inline-block;flex-shrink:0;"></span>${p.anime}</div><div class="near-place">${pl(p)}</div><div class="near-ep">${ep(p)}</div></div><div class="near-right">${d!==undefined?`<span class="dist-badge${near?' near':''}">${near?'&#x2605; ':''}${fmtDist(d)}</span>`:''}<span class="detail-btn-sm"><i class="ti ti-chevron-right"></i>Detail</span></div></div>`;}).join('');
}

// ── Sheet ─────────────────────────────────────────
function toggleSheet(){
  const cur=document.getElementById('sheetContent').classList.contains('collapsed')?'collapsed':parseInt(document.getElementById('sheetContent').style.maxHeight||0)<300?'half':'full';
  const next=cur==='collapsed'?'half':cur==='half'?'full':'collapsed';
  sheetOpen=next!=='collapsed';
  const cont=document.getElementById('sheetContent'),H={collapsed:0,half:220,full:Math.round(window.innerHeight*0.65)};
  cont.style.maxHeight=H[next]+'px';cont.style.overflow='auto';
  if(next==='collapsed')cont.classList.add('collapsed');else cont.classList.remove('collapsed');
}

// ── Swipe ─────────────────────────────────────────
(function(){
  let sy=0,sh=0,drag=false;
  const SU=60,SD=60,H={collapsed:0,half:220,full:0};let snap='collapsed';
  function gh(){H.full=Math.round(window.innerHeight*0.65);return H;}
  function applyH(h,anim){const c=document.getElementById('sheetContent');if(!c)return;c.style.transition=anim?'max-height .3s ease':'none';c.style.maxHeight=h+'px';c.style.overflow='auto';if(h===0){c.classList.add('collapsed');sheetOpen=false;}else{c.classList.remove('collapsed');sheetOpen=true;}}
  function snapTo(s,anim=true){snap=s;applyH(gh()[s],anim);}
  window.addEventListener('DOMContentLoaded',()=>{
    const hr=document.querySelector('.sheet-handle-row');if(!hr)return;
    function onDown(e){drag=true;sy=e.touches?e.touches[0].clientY:e.clientY;sh=parseInt(document.getElementById('sheetContent').style.maxHeight||0);document.getElementById('sheetContent').style.transition='none';e.preventDefault();}
    function onMove(e){if(!drag)return;const cy=e.touches?e.touches[0].clientY:e.clientY,dy=sy-cy,nh=Math.max(0,Math.min(gh().full,sh+dy));applyH(nh,false);e.preventDefault();}
    function onUp(e){if(!drag)return;drag=false;const cy=e.changedTouches?e.changedTouches[0].clientY:e.clientY,dy=sy-cy;if(dy>SU)snapTo(snap==='full'?'full':snap==='half'?'full':'half');else if(dy<-SD)snapTo(snap==='full'?'half':snap==='half'?'collapsed':'collapsed');else snapTo(snap);}
    hr.addEventListener('touchstart',onDown,{passive:false});hr.addEventListener('mousedown',onDown);
    document.addEventListener('touchmove',onMove,{passive:false});document.addEventListener('mousemove',onMove);
    document.addEventListener('touchend',onUp);document.addEventListener('mouseup',onUp);
  });
})();

document.addEventListener('click',e=>{if(!document.getElementById('animeWrap').contains(e.target)){document.getElementById('animePill').classList.remove('open');document.getElementById('animeDD').classList.remove('open');ddOpen=false;}});

// ── Init ──────────────────────────────────────────
initMap();
ALL_PINS.forEach(p=>addPin(p));
applyFilter();
if(pins.length){const g=L.featureGroup(markers.map(m=>m.marker));map.fitBounds(g.getBounds().pad(0.08));}
</script>
</body>
