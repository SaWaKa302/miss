  map=L.map('map',{tap:true,zoomControl:false}).setView([36.5,136.5],6);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',{attribution:'&copy; OpenStreetMap contributors &copy; CARTO',subdomains:'abcd',maxZoom:19}).addTo(map);
}

function addPin(data){
  const pin={...data,id:data.id||(Date.now()+Math.random())};
  pins.push(pin);
  const marker=L.marker([pin.lat,pin.lng],{icon:makeIcon(getColor(pin.anime),null,false)}).addTo(map);
  marker.on('click',()=>{
    if(pilMode&&!pilActive){
      if(pin.anime!==pilAnime){showToast('This pin is from another anime');return;}
      if(pilOrder[pin.id]){const r=pilOrder[pin.id];delete pilOrder[pin.id];Object.keys(pilOrder).forEach(k=>{if(pilOrder[k]>r)pilOrder[k]--;});pilNextOrder=Object.keys(pilOrder).length+1;showToast('Order removed');}
      else{pilOrder[pin.id]=pilNextOrder++;showToast(`${pl(pin)} added as #${pilOrder[pin.id]}`);}
      updateBanner();refreshMarkers();renderListSheetBody();
    }else{openDetail(pin.id);}
  });
  markers.push({pin,marker,id:pin.id});
}
function refreshMarkers(){markers.forEach(({pin,marker})=>marker.setIcon(makeIcon(getColor(pin.anime),pilOrder[pin.id]?String(pilOrder[pin.id]):null,!!pilDone[pin.id])));}

// ── Route ─────────────────────────────────────────
function calcDist(spots){let t=0;for(let i=0;i<spots.length-1;i++)t+=dist(spots[i].lat,spots[i].lng,spots[i+1].lat,spots[i+1].lng);return t;}
function sortRoute(spots){const b=spots[0];return [...spots].sort((a,z)=>{const ta=TIME_ORDER.indexOf(a.time||'All day'),tz=TIME_ORDER.indexOf(z.time||'All day');if(ta!==tz)return ta-tz;return dist(b.lat,b.lng,a.lat,a.lng)-dist(b.lat,b.lng,z.lat,z.lng);});}
function clusterSpots(spots,km=60){const c=[],u=new Set();spots.forEach((s,i)=>{if(u.has(i))return;const g=[s];u.add(i);spots.forEach((t,j)=>{if(!u.has(j)&&dist(s.lat,s.lng,t.lat,t.lng)/1000<km){g.push(t);u.add(j);}});c.push(g);});return c;}
function getAreaLabel(spots){const m=(spots[0].access||'').match(/([A-Z][a-z]+(?: [A-Z][a-z]+)*)/);return m?m[1]:'Area';}
function buildRoute(spots,multiDay,areaIdx,timeSlot){
  const clusters=clusterSpots(spots);
  if(multiDay)return clusters.map(c=>sortRoute(c));
  const target=areaIdx!=null?clusters[areaIdx]:spots;
  if(timeSlot==='range'){const f=target.filter(s=>{const i=TIME_LABELS.indexOf(s.time);return i===-1||(i>=sliderStart&&i<=sliderEnd);});return[f.length?sortRoute(f):sortRoute(target)];}
  return[sortRoute(target)];
}
function distComment(spots){if(spots.length<2)return '';const km=calcDist(spots)/1000;if(km<=30)return `<span style="color:#1D9E75;">&#x2713; ~${km.toFixed(0)}km total &mdash; Comfortable for one day</span>`;if(km<=100)return `<span style="color:#BA7517;">&#x26A0; ~${km.toFixed(0)}km total &mdash; A lot of travel but doable</span>`;return `<span style="color:#E24B4A;">&#x26A0; ~${km.toFixed(0)}km total &mdash; Consider splitting across multiple days</span>`;}

// ── Susume ────────────────────────────────────────
function renderSusume(p){
  const as=ALL_PINS.filter(s=>s.anime===p.anime);if(as.length<2)return '';
  const color=getColor(p.anime),allR=sortRoute(as),nightR=sortRoute(as.filter(s=>s.time==='Evening'||s.time==='Night'));
  function stops(spots,cid){
    if(!spots.length)return '<div class="susume-empty">No spots</div>';
    return spots.map((s,i)=>{const cur=String(s.id)===String(cid),last=i===spots.length-1;
      return `<div class="susume-stop"><div class="susume-line"><div class="susume-circle" style="background:${cur?'var(--blue)':color}">${i+1}</div>${!last?'<div class="susume-connector"></div>':''}</div><div class="susume-info"><div class="susume-place">${pl(s)}${cur?' <span class="susume-current-badge">&#x2190; You are here</span>':''}</div><div class="susume-meta">${s.time?`<span class="susume-time-chip">${s.time}</span>`:''}<span class="susume-ep-chip">${ep(s)}</span></div></div></div>`;
    }).join('');
  }
  const uid=String(p.id).replace('.','');
  return `<div class="susume-section"><div class="susume-header"><span class="susume-title">Pilgrimage Guide</span><div class="susume-tabs"><button class="susume-tab active" onclick="switchTab(this,'sa-${uid}','sn-${uid}')">Full Day</button><button class="susume-tab" onclick="switchTab(this,'sn-${uid}','sa-${uid}')">Evening</button></div></div><div id="sa-${uid}"><div class="susume-comment">${distComment(allR)}</div><div class="susume-route">${stops(allR,p.id)}</div></div><div id="sn-${uid}" style="display:none">${nightR.length?`<div class="susume-comment">${distComment(nightR)}</div><div class="susume-route">${stops(nightR,p.id)}</div>`:'<div class="susume-empty">No evening/night spots</div>'}</div></div>`;
}
function switchTab(btn,show,hide){document.getElementById(show).style.display='block';document.getElementById(hide).style.display='none';btn.parentElement.querySelectorAll('.susume-tab').forEach(t=>t.classList.remove('active'));btn.classList.add('active');}

// ── Feedback ──────────────────────────────────────
