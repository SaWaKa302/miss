// ── Wizard ────────────────────────────────────────
function openWizardModal(){document.getElementById('wizardTitle').textContent='Pilgrimage Guide';document.getElementById('wizardOverlay').classList.add('open');startWizard();}
function closeWizardModal(){document.getElementById('wizardOverlay').classList.remove('open');}
function onWizardOverlayClick(e){if(e.target===document.getElementById('wizardOverlay'))closeWizardModal();}
function wizardSetBody(h){document.getElementById('wizardModalBody').innerHTML=h;}
function startWizard(){
  wizardState={};
  wizardSetBody('<div class="wizard-q">Q1. Will you visit over multiple days?</div><div class="wizard-sub">If spots are spread across different areas, splitting by day makes it easier.</div><div class="wizard-choices"><button class="wizard-btn" onclick="wizardAnswer(1,\'yes\')"><span class="wbtn-icon">&#x1F4C5;</span><span class="wbtn-text">Yes<span class="wbtn-desc">Split into areas across multiple days</span></span></button><button class="wizard-btn" onclick="wizardAnswer(1,\'no\')"><span class="wbtn-icon">&#x26A1;</span><span class="wbtn-text">No, all in one day<span class="wbtn-desc">Visit as many spots as possible in one day</span></span></button></div>');
}
function wizardAnswer(step,value){
  const spots=pins.filter(p=>p.anime===pilAnime),clusters=clusterSpots(spots);
  if(step===1){
    wizardState.multiDay=(value==='yes');
    if(wizardState.multiDay){wizardState.areaIdx=null;wizardState.timeSlot='full';renderWizardResult();}
    else if(clusters.length<=1){wizardState.areaIdx=0;showWizardQ3();}
    else{wizardSetBody(`<button class="wizard-back" onclick="startWizard()">&#x2190; Back</button><div class="wizard-q">Q2. Which area will you visit?</div><div class="wizard-sub">Spots are in multiple areas. Choose one for your one-day trip.</div><div class="wizard-choices">${clusters.map((c,i)=>`<button class="wizard-btn" onclick="wizardAnswer(2,${i})"><span class="wbtn-icon">&#x1F4CD;</span><span class="wbtn-text">${getAreaLabel(c)}<span class="wbtn-desc">${c.map(s=>pl(s)).join(', ')}</span></span></button>`).join('')}<button class="wizard-btn" onclick="wizardAnswer(2,-1)"><span class="wbtn-icon">&#x1F5FE;</span><span class="wbtn-text">All areas<span class="wbtn-desc">Longer travel distance</span></span></button></div>`);}
  }else if(step===2){wizardState.areaIdx=value===-1?null:value;showWizardQ3();}
  else if(step===3){wizardState.timeSlot=value;renderWizardResult();}
}
function showWizardQ3(){
  sliderStart=0;sliderEnd=TIME_LABELS.length-1;
  wizardSetBody(`<button class="wizard-back" onclick="startWizard()">&#x2190; Back</button><div class="wizard-q">Q3. Choose your time range</div><div class="wizard-sub">Drag the handles to set your preferred time range.</div><div class="time-slider-wrap"><div class="time-slider-labels">${TIME_LABELS.map(l=>`<span class="time-slider-label">${l}</span>`).join('')}</div><div class="time-slider-track" id="sliderTrack"><div class="time-slider-rail"></div><div class="time-slider-range" id="sliderRange"></div><div class="time-slider-thumb" id="thumbStart"></div><div class="time-slider-thumb" id="thumbEnd"></div></div><div class="time-slider-selected" id="sliderSelected"></div></div><button class="wizard-use-btn" style="background:#1a1a2e;margin-top:4px;" onclick="wizardAnswer(3,\'range\')">Preview this route</button>`);
  requestAnimationFrame(initSlider);
}
function initSlider(){
  const track=document.getElementById('sliderTrack');if(!track)return;
  updateSliderUI();
  function getPos(e){const r=track.getBoundingClientRect(),cx=e.touches?e.touches[0].clientX:e.clientX;return Math.max(0,Math.min(1,(cx-r.left)/r.width));}
  function toIdx(pos){return Math.round(pos*(TIME_LABELS.length-1));}
  function onMove(e){if(!dragging)return;e.preventDefault();const i=toIdx(getPos(e));if(dragging==='start')sliderStart=Math.min(i,sliderEnd);else sliderEnd=Math.max(i,sliderStart);updateSliderUI();}
  function onUp(){dragging=null;}
  document.getElementById('thumbStart').addEventListener('mousedown',e=>{dragging='start';e.preventDefault();});
  document.getElementById('thumbEnd').addEventListener('mousedown',e=>{dragging='end';e.preventDefault();});
  document.getElementById('thumbStart').addEventListener('touchstart',()=>{dragging='start';},{passive:true});
  document.getElementById('thumbEnd').addEventListener('touchstart',()=>{dragging='end';},{passive:true});
  document.addEventListener('mousemove',onMove);document.addEventListener('mouseup',onUp);
  document.addEventListener('touchmove',onMove,{passive:false});document.addEventListener('touchend',onUp);
}
function updateSliderUI(){
  const n=TIME_LABELS.length-1,sp=sliderStart/n*100,ep2=sliderEnd/n*100;
  const ts=document.getElementById('thumbStart'),te=document.getElementById('thumbEnd'),rng=document.getElementById('sliderRange'),sel=document.getElementById('sliderSelected');
  if(!ts||!te||!rng||!sel)return;
  ts.style.left=sp+'%';te.style.left=ep2+'%';rng.style.left=sp+'%';rng.style.width=(ep2-sp)+'%';
  sel.textContent=sliderStart===sliderEnd?TIME_LABELS[sliderStart]:`${TIME_LABELS[sliderStart]} - ${TIME_LABELS[sliderEnd]}`;
}
function routeHTML(dayRoutes,color){
  return dayRoutes.map((spots,di)=>{
    const km=calcDist(spots)/1000;
    const warn=km>100?`<span style="color:#E24B4A;">&#x26A0; ~${km.toFixed(0)}km - Consider splitting</span>`:km>30?`<span style="color:#BA7517;">&#x26A0; ~${km.toFixed(0)}km - A lot of travel</span>`:`<span style="color:#1D9E75;">&#x2713; ~${km.toFixed(0)}km - Comfortable</span>`;
    const stopsH=spots.map((s,i)=>`<div class="wizard-stop"><div class="wizard-line"><div class="wizard-circle" style="background:${color}">${i+1}</div>${i<spots.length-1?'<div class="wizard-connector"></div>':''}</div><div class="wizard-stop-info"><div class="wizard-stop-place">${pl(s)}</div><div class="wizard-stop-meta">${s.time?`<span class="wizard-time-chip">${s.time}</span>`:''}<span class="wizard-ep-chip">${ep(s)}</span></div></div></div>`).join('');
    return `<div class="wizard-day-block">${dayRoutes.length>1?`<div class="wizard-day-label">Day ${di+1} - ${spots.length} spots</div>`:''}<div class="wizard-result-comment">${warn}</div><div class="wizard-route">${stopsH}</div></div>`;
  }).join('');
}
function renderWizardResult(){
  const spots=pins.filter(p=>p.anime===pilAnime),color=getColor(pilAnime);
  const {multiDay,areaIdx,timeSlot}=wizardState,dayRoutes=buildRoute(spots,multiDay,areaIdx,timeSlot);
  wizardSetBody(`<div>${routeHTML(dayRoutes,color)}<button class="wizard-use-btn" onclick="applyWizardRoute()">Start this route</button><button class="wizard-restart" onclick="startWizard()">&#x2190; Start over</button></div>`);
}
function applyWizardRoute(){
  const spots=pins.filter(p=>p.anime===pilAnime),{multiDay,areaIdx,timeSlot}=wizardState;
  const dayRoutes=buildRoute(spots,multiDay,areaIdx,timeSlot);
  pilOrder={};let i=1;dayRoutes.forEach(day=>day.forEach(s=>{pilOrder[s.id]=i++;}));pilNextOrder=i;
  closeWizardModal();startPilgrimage();
}

