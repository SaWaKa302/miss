function setFbStar(id,n){initFB(id);feedbacks[id].star=n;renderFeedback(id);}
function toggleFbTag(id,type,tag){initFB(id);const a=feedbacks[id][type],i=a.indexOf(tag);if(i===-1)a.push(tag);else a.splice(i,1);renderFeedback(id);}
async function sendFeedback(id){
