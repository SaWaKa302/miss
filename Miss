    { place:'NTT Docomo Yoyogi Building View', lat:35.6835, lng:139.7145, episode:'Opening Sequence', time:'Morning', desc:"The famous sunrise landscape shot featuring the clock tower skyscraper. It symbolizes Taki's mornings in Tokyo. Best viewed from the pedestrian bridge near Shinjuku Gyoen.", access:'About 8 minutes on foot from Sendagaya Station or Shinanomachi Station.' },
