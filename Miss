    { place:'Hida-Furukawa Station', lat:36.2361, lng:137.1862, episode:'Search Scenes', time:'Noon', desc:"The rural train station where Taki and his friends arrive to search for Mitsuha's hometown. The iconic view looking down at the tracks matches the movie flawlessly.", access:'About 2.5 hours from Nagoya via JR Hida Wide View Express, or 15 minutes from Takayama Station.' },
    { place:'Hida City Library', lat:36.2346, lng:137.1876, episode:'Researching the Comet', time:'Noon', desc:'The public library where Taki desperately researches the history of Itomori and the comet disaster. Photography permitted with a permit from the front desk.', access:'About 5 minutes on foot from Hida-Furukawa Station.' },
    { place:'Ajisaka Bus Stop', lat:36.2847, lng:137.1332, episode:'Search Scenes', time:'Noon', desc:'The tiny wooden bus stop where Taki, Tsukasa, and Okudera rest after getting lost during their search for Itomori. A charming and peaceful spot.', access:'In Miyagawa-cho, Hida City. Taxi from Hida-Furukawa Station recommended (approx. 15-20 mins).' },
