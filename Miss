  { title:'Hyouka', spots:[
    { place:'Honmachi Street', lat:36.1461, lng:137.2579, episode:'Multiple Episodes', time:'Evening', desc:'One of the most iconic locations in Hyouka. The traditional streets of Takayama perfectly capture the calm and nostalgic atmosphere of the series.', access:'About 12 minutes on foot from Takayama Station' },
    { place:'Yayoi Bridge', lat:36.1455, lng:137.2591, episode:'Daily Life Scenes', time:'Evening', desc:'A famous bridge frequently associated with Oreki and the members of the Classic Literature Club. The riverside atmosphere becomes especially beautiful at sunset.', access:'About 10 minutes on foot from Takayama Station' },
    { place:'Miyagawa Morning Market', lat:36.1467, lng:137.2602, episode:'Town Scenes', time:'Morning', desc:'A lively traditional market area that reflects the everyday atmosphere seen throughout Hyouka. Morning visits are highly recommended.', access:'About 13 minutes on foot from Takayama Station' },
