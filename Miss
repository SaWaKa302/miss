<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
<title>Anime Seichi Map</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css"/>
<style>
:root{--bg:#fff;--bg2:#f5f5f5;--bg3:#ebebeb;--border:#e0e0e0;--border2:#ccc;--text:#111;--text2:#555;--text3:#999;--blue:#378ADD;--blue-light:#E6F1FB;--green:#1D9E75;--green-light:#E1F5EE;--r-sm:8px;--r-md:12px;--r-lg:16px;}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;background:#1a1a2e;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;display:flex;align-items:center;justify-content:center;}
.phone-frame{width:390px;height:844px;position:relative;border-radius:44px;overflow:hidden;box-shadow:0 0 0 10px #2a2a3e,0 0 0 12px #3a3a5e,0 30px 80px rgba(0,0,0,.6);flex-shrink:0;}
@media(max-width:430px){html,body{background:#fff;display:block;height:100%;}.phone-frame{width:100%;height:100dvh;border-radius:0;box-shadow:none;}}
#app{display:flex;flex-direction:column;height:100%;position:relative;overflow:hidden;background:#f0f0f0;}
#map{flex:1;width:100%;z-index:0;}
.top-ui{position:absolute;top:0;left:0;right:0;z-index:10;padding:12px 12px 0;display:flex;flex-direction:column;gap:6px;}
.search-row{display:flex;gap:6px;align-items:center;}
.search-pill{flex:1;display:flex;align-items:center;gap:7px;background:var(--bg);border:0.5px solid var(--border);border-radius:99px;padding:10px 14px;box-shadow:0 1px 6px rgba(0,0,0,.12);}
.search-pill i{font-size:17px;color:var(--text3);flex-shrink:0;}
.search-pill input{border:none;background:none;font-size:14px;color:var(--text);outline:none;width:100%;}
.search-pill input::placeholder{color:var(--text3);}
.anime-pill-wrap{position:relative;flex:1;}
.anime-pill{width:100%;display:flex;align-items:center;gap:7px;background:var(--bg);border:0.5px solid var(--border);border-radius:99px;padding:10px 14px;cursor:pointer;box-shadow:0 1px 6px rgba(0,0,0,.12);}
.anime-pill i{font-size:17px;color:var(--text3);flex-shrink:0;}
.anime-pill-label{font-size:14px;color:var(--text3);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.anime-pill-label.chosen{color:var(--text);}
.anime-pill .chev{font-size:15px;margin-left:auto;flex-shrink:0;transition:transform .2s;}
.anime-pill.open .chev{transform:rotate(180deg);}
.anime-dd{position:absolute;top:calc(100% + 6px);left:0;right:0;background:var(--bg);border:0.5px solid var(--border);border-radius:var(--r-lg);z-index:100;max-height:260px;overflow-y:auto;display:none;box-shadow:0 4px 20px rgba(0,0,0,.14);}
.anime-dd.open{display:block;}
.dd-search-row{padding:10px;border-bottom:0.5px solid var(--border);}
.dd-search-row input{width:100%;font-size:14px;padding:8px 12px;border-radius:var(--r-sm);border:0.5px solid var(--border);background:var(--bg2);color:var(--text);outline:none;}
.dd-all{padding:13px 14px;font-size:14px;color:var(--text2);cursor:pointer;border-bottom:0.5px solid var(--border);}
.dd-all:active{background:var(--bg2);}
.dd-item{padding:13px 14px;font-size:14px;cursor:pointer;display:flex;align-items:center;gap:10px;color:var(--text);border-bottom:0.5px solid var(--border);}
.dd-item:last-child{border-bottom:none;}
.dd-item:active,.dd-item.sel{background:var(--bg2);}
.dd-item.sel{font-weight:500;}
.dd-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.dd-cnt{margin-left:auto;font-size:13px;color:var(--text3);}
.icon-btn{width:46px;height:46px;border-radius:50%;background:var(--bg);border:0.5px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;font-size:22px;color:var(--text2);box-shadow:0 1px 6px rgba(0,0,0,.12);}
.icon-btn.active{color:var(--blue);border-color:var(--blue);}
.pil-banner{display:none;align-items:center;gap:8px;background:var(--green);border-radius:var(--r-lg);padding:10px 14px;}
.pil-banner.visible{display:flex;}
.pil-banner-text{color:#fff;font-size:13px;font-weight:500;flex:1;line-height:1.4;}
.pil-exit-btn{background:rgba(255,255,255,.25);border:none;color:#fff;font-size:13px;padding:6px 12px;border-radius:99px;cursor:pointer;white-space:nowrap;flex-shrink:0;}
.loc-banner{position:absolute;bottom:70px;left:12px;right:12px;z-index:20;background:var(--bg);border:0.5px solid var(--border);border-radius:var(--r-lg);padding:11px 14px;font-size:13px;color:var(--text2);display:none;align-items:center;gap:8px;box-shadow:0 2px 8px rgba(0,0,0,.12);}
.loc-banner i{font-size:19px;color:var(--blue);}
.toast{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) scale(.85);z-index:9999;background:rgba(0,0,0,.80);color:#fff;font-size:15px;font-weight:500;padding:13px 24px;border-radius:99px;pointer-events:none;opacity:0;transition:opacity .2s,transform .2s;white-space:nowrap;}
.toast.show{opacity:1;transform:translate(-50%,-50%) scale(1);}
.bottom-sheet{position:absolute;bottom:0;left:0;right:0;z-index:10;background:var(--bg);border-radius:18px 18px 0 0;border-top:0.5px solid var(--border);box-shadow:0 -2px 14px rgba(0,0,0,.10);}
.sheet-handle-row{padding:10px 0 4px;display:flex;justify-content:center;cursor:pointer;}
.sheet-handle{width:38px;height:4px;border-radius:99px;background:var(--border2);}
.sheet-header{padding:2px 16px 10px;display:flex;align-items:center;justify-content:space-between;gap:8px;}
.sheet-title{font-size:15px;font-weight:600;color:var(--text);flex:1;}
.sheet-count{font-size:13px;color:var(--text3);white-space:nowrap;}
.pil-start-btn{display:flex;align-items:center;gap:5px;padding:8px 16px;border-radius:99px;background:var(--green);color:#fff;font-size:14px;font-weight:500;cursor:pointer;border:none;white-space:nowrap;}
.pil-start-btn:disabled{background:var(--border2);cursor:default;}
.sheet-content{overflow-y:auto;-webkit-overflow-scrolling:touch;}
.sheet-content.collapsed{display:none;}
.near-item{padding:13px 16px;border-top:0.5px solid var(--border);display:flex;align-items:center;gap:10px;cursor:pointer;background:var(--bg);}
.near-item:active{background:var(--bg2);}
.near-left{flex:1;min-width:0;}
.near-anime{font-size:12px;color:var(--text3);margin-bottom:2px;display:flex;align-items:center;gap:5px;}
.near-place{font-size:15px;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.near-ep{font-size:12px;color:var(--text2);margin-top:2px;}
.near-right{display:flex;flex-direction:column;align-items:flex-end;gap:5px;flex-shrink:0;}
.dist-badge{font-size:12px;font-weight:500;padding:3px 9px;border-radius:99px;background:var(--bg2);color:var(--text2);white-space:nowrap;}
.dist-badge.near{background:#E1F5EE;color:#0F6E56;}
.detail-btn-sm{display:flex;align-items:center;gap:4px;font-size:12px;padding:5px 10px;border-radius:99px;border:0.5px solid var(--border);color:var(--text2);background:var(--bg2);}
.order-badge{width:30px;height:30px;border-radius:50%;border:2px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:var(--text3);background:var(--bg);flex-shrink:0;}
.order-badge.assigned{color:#fff;border-color:transparent;}
.pil-hud{position:absolute;bottom:0;left:0;right:0;z-index:15;display:none;pointer-events:none;}
.pil-hud.visible{display:block;}
.pil-next-card{background:var(--bg);border-radius:var(--r-lg) var(--r-lg) 0 0;box-shadow:0 -2px 14px rgba(0,0,0,.12);padding:14px 16px 10px;pointer-events:all;}
.pil-progress{display:flex;align-items:center;gap:6px;margin-bottom:10px;}
.pil-progress-bar{flex:1;height:4px;background:var(--bg3);border-radius:99px;overflow:hidden;}
.pil-progress-fill{height:100%;background:var(--green);border-radius:99px;transition:width .4s;}
.pil-progress-text{font-size:12px;color:var(--text3);white-space:nowrap;}
.pil-next-label{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;}
.pil-next-place{font-size:17px;font-weight:700;color:var(--text);margin-bottom:3px;}
.pil-next-meta{font-size:12px;color:var(--text2);margin-bottom:10px;display:flex;gap:12px;}
.pil-next-actions{display:flex;gap:8px;}
.pil-nav-big{flex:1;display:flex;align-items:center;justify-content:center;gap:6px;padding:12px;border-radius:var(--r-md);background:var(--blue);color:#fff;font-size:14px;font-weight:500;text-decoration:none;}
.pil-arrived-btn{flex:1;display:flex;align-items:center;justify-content:center;gap:6px;padding:12px;border-radius:var(--r-md);background:var(--green-light);border:1.5px solid var(--green);color:var(--green);font-size:14px;font-weight:500;cursor:pointer;}
.pil-item{padding:13px 16px;border-top:0.5px solid var(--border);display:flex;align-items:center;gap:10px;background:var(--bg);cursor:pointer;}
.pil-item:active{background:var(--bg2);}
.pil-item.done{background:#f0faf6;}
.pil-num{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#fff;flex-shrink:0;}
.pil-info{flex:1;min-width:0;}
.pil-place{font-size:15px;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.pil-sub{font-size:12px;color:var(--text2);margin-top:2px;}
.pil-right{display:flex;flex-direction:column;align-items:flex-end;gap:5px;flex-shrink:0;}
.pil-done-badge{font-size:11px;padding:3px 9px;border-radius:99px;background:#E1F5EE;color:#0F6E56;font-weight:500;}
.pil-nav-btn{font-size:12px;padding:6px 10px;border-radius:99px;background:var(--blue-light);border:0.5px solid #B5D4F4;color:#185FA5;text-decoration:none;white-space:nowrap;display:flex;align-items:center;gap:3px;}
.detail-overlay{position:absolute;inset:0;z-index:30;background:rgba(0,0,0,.42);display:none;}
.detail-overlay.open{display:block;}
.detail-sheet{position:absolute;bottom:0;left:0;right:0;z-index:40;background:var(--bg);border-radius:22px 22px 0 0;transform:translateY(100%);transition:transform .32s cubic-bezier(.32,1,.4,1);max-height:90%;display:flex;flex-direction:column;box-shadow:0 -4px 28px rgba(0,0,0,.16);}
.detail-sheet.open{transform:translateY(0);}
.detail-handle-row{padding:10px 0 4px;display:flex;justify-content:center;flex-shrink:0;}
.detail-handle{width:38px;height:4px;border-radius:99px;background:var(--border2);}
.detail-scroll{overflow-y:auto;flex:1;padding-bottom:8px;}
.detail-hero-ph{width:100%;height:150px;background:var(--bg2);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:6px;color:var(--text3);font-size:13px;}
.detail-hero-ph i{font-size:30px;}
.detail-body{padding:16px 16px 0;}
.d-anime-row{display:flex;align-items:center;gap:6px;margin-bottom:5px;}
.d-anime-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.d-anime-name{font-size:12px;color:var(--text3);}
.d-place{font-size:21px;font-weight:600;color:var(--text);margin-bottom:3px;}
.d-ep{font-size:13px;color:var(--text2);margin-bottom:12px;}
.dsec{margin-bottom:16px;}
.dsec-title{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px;}
.dsec-desc{font-size:14px;color:var(--text);line-height:1.75;}
.dsec-row2{display:flex;gap:8px;}
.dsec-access{flex:1;font-size:14px;color:var(--text);background:var(--bg2);border-radius:var(--r-sm);padding:11px 13px;display:flex;align-items:flex-start;gap:8px;line-height:1.6;}
.dsec-access i{font-size:18px;color:var(--text3);flex-shrink:0;margin-top:2px;}
.time-badge{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;padding:10px 14px;border-radius:var(--r-sm);background:#FFF8E7;border:0.5px solid #F0D080;flex-shrink:0;min-width:72px;}
.time-badge-label{font-size:10px;color:#B8960A;font-weight:600;text-transform:uppercase;}
.time-badge-val{font-size:15px;font-weight:700;color:#8A6800;}
.memo-area{width:100%;font-size:14px;color:var(--text);background:var(--bg2);border:0.5px solid var(--border);border-radius:var(--r-sm);padding:11px 13px;resize:none;outline:none;line-height:1.6;font-family:inherit;min-height:80px;}
.memo-area::placeholder{color:var(--text3);}
.memo-save-btn{margin-top:7px;font-size:14px;padding:8px 18px;border-radius:99px;background:var(--bg2);border:0.5px solid var(--border);color:var(--text2);cursor:pointer;}
.memo-save-btn.saved{background:#E1F5EE;color:#0F6E56;border-color:#0F6E56;}
.nav-row{padding:10px 16px 20px;flex-shrink:0;background:var(--bg);}
.nav-row-inner{display:flex;gap:8px;}
.nav-big-btn{flex:1;display:flex;align-items:center;justify-content:center;gap:8px;padding:15px;border-radius:var(--r-lg);background:var(--blue);color:#fff;font-size:15px;font-weight:500;text-decoration:none;}
.arrived-from-detail{flex:1;display:flex;align-items:center;justify-content:center;gap:6px;padding:15px;border-radius:var(--r-lg);background:var(--green-light);border:1.5px solid var(--green);color:var(--green);font-size:15px;font-weight:500;cursor:pointer;}
.detail-close{position:absolute;top:18px;right:16px;width:34px;height:34px;border-radius:50%;background:var(--bg2);border:0.5px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px;color:var(--text2);z-index:1;}
.empty-sheet{padding:28px 16px;text-align:center;color:var(--text3);font-size:14px;}
.pil-mode-select{padding:12px 16px;}
.pil-mode-title{font-size:12px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px;}
.pil-mode-cards{display:flex;gap:8px;}
.pil-mode-card{flex:1;border:1.5px solid var(--border);border-radius:var(--r-lg);padding:12px 10px;cursor:pointer;text-align:center;background:var(--bg);}
.pil-mode-card.selected{border-color:#1a1a2e;background:#1a1a2e;}
.pil-mode-card.selected .pil-mode-card-label{color:#fff;}
.pil-mode-card.selected .pil-mode-card-desc{color:rgba(255,255,255,.7);}
.pil-mode-card-icon{font-size:22px;margin-bottom:5px;}
.pil-mode-card-label{font-size:13px;font-weight:600;color:var(--text);margin-bottom:3px;}
.pil-mode-card-desc{font-size:11px;color:var(--text3);line-height:1.4;}
.wizard-modal-overlay{position:absolute;inset:0;z-index:50;background:rgba(0,0,0,.45);display:none;align-items:flex-end;}
.wizard-modal-overlay.open{display:flex;}
.wizard-modal{width:100%;background:var(--bg);border-radius:22px 22px 0 0;padding:0 0 24px;max-height:85%;display:flex;flex-direction:column;}
.wizard-modal-handle-row{padding:10px 0 4px;display:flex;justify-content:center;flex-shrink:0;}
.wizard-modal-handle{width:38px;height:4px;border-radius:99px;background:var(--border2);}
.wizard-modal-header{padding:4px 16px 12px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;border-bottom:0.5px solid var(--border);}
.wizard-modal-title{font-size:15px;font-weight:700;color:var(--text);}
.wizard-modal-close{width:30px;height:30px;border-radius:50%;background:var(--bg2);border:none;cursor:pointer;font-size:16px;color:var(--text2);}
.wizard-modal-body{overflow-y:auto;flex:1;padding:16px;}
.wizard-q{font-size:15px;font-weight:600;color:var(--text);margin-bottom:4px;}
.wizard-sub{font-size:12px;color:var(--text3);margin-bottom:12px;line-height:1.5;}
.wizard-choices{display:flex;flex-direction:column;gap:8px;}
.wizard-btn{width:100%;padding:12px 14px;border-radius:var(--r-lg);border:1.5px solid var(--border);background:var(--bg);font-size:14px;font-weight:500;color:var(--text);cursor:pointer;text-align:left;display:flex;align-items:center;gap:10px;}
.wbtn-icon{font-size:20px;flex-shrink:0;}
.wbtn-text{flex:1;}
.wbtn-desc{font-size:11px;color:var(--text3);font-weight:400;display:block;margin-top:1px;}
.wizard-back{background:none;border:none;color:var(--text3);font-size:13px;cursor:pointer;padding:8px 0 4px;display:flex;align-items:center;gap:4px;}
.wizard-result-comment{font-size:13px;color:var(--text2);background:#F0F4FF;border-radius:var(--r-sm);padding:10px 12px;margin-bottom:10px;line-height:1.6;}
.wizard-day-block{margin-bottom:14px;}
.wizard-day-label{font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;padding-bottom:4px;border-bottom:0.5px solid var(--border);}
.wizard-route{display:flex;flex-direction:column;}
.wizard-stop{display:flex;align-items:flex-start;gap:10px;padding:7px 0;}
.wizard-stop:not(:last-child){border-bottom:0.5px solid var(--border);}
.wizard-line{display:flex;flex-direction:column;align-items:center;flex-shrink:0;width:28px;}
.wizard-circle{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;}
.wizard-connector{width:2px;flex:1;min-height:10px;background:var(--border2);margin-top:2px;}
.wizard-stop-info{flex:1;min-width:0;padding-top:3px;}
.wizard-stop-place{font-size:14px;font-weight:500;color:var(--text);}
.wizard-stop-meta{display:flex;gap:5px;margin-top:3px;flex-wrap:wrap;}
.wizard-time-chip{font-size:11px;padding:2px 7px;border-radius:99px;background:#FFF8E7;color:#8A6800;border:0.5px solid #F0D080;font-weight:500;}
.wizard-ep-chip{font-size:11px;padding:2px 7px;border-radius:99px;background:var(--bg2);color:var(--text3);}
.wizard-use-btn{width:100%;padding:12px;border-radius:var(--r-lg);background:#1a1a2e;color:#fff;font-size:14px;font-weight:600;border:none;cursor:pointer;margin-top:10px;}
.wizard-restart{width:100%;padding:10px;border-radius:var(--r-lg);background:var(--bg2);color:var(--text2);font-size:13px;border:0.5px solid var(--border);cursor:pointer;margin-top:6px;}
.susume-section{margin-bottom:16px;}
.susume-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
.susume-title{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;}
.susume-tabs{display:flex;gap:4px;}
.susume-tab{font-size:11px;padding:4px 10px;border-radius:99px;border:0.5px solid var(--border);background:var(--bg2);color:var(--text2);cursor:pointer;}
.susume-tab.active{background:#1a1a2e;color:#fff;border-color:transparent;}
.susume-comment{font-size:13px;color:var(--text2);background:#F0F4FF;border-radius:var(--r-sm);padding:10px 12px;margin-bottom:10px;line-height:1.6;}
.susume-route{display:flex;flex-direction:column;}
.susume-stop{display:flex;align-items:flex-start;gap:10px;padding:8px 0;}
.susume-stop:not(:last-child){border-bottom:0.5px solid var(--border);}
.susume-line{display:flex;flex-direction:column;align-items:center;flex-shrink:0;width:28px;}
.susume-circle{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;}
.susume-connector{width:2px;flex:1;min-height:10px;background:var(--border2);margin-top:2px;}
.susume-info{flex:1;min-width:0;padding-top:3px;}
.susume-place{font-size:14px;font-weight:500;color:var(--text);}
.susume-meta{display:flex;gap:5px;margin-top:3px;flex-wrap:wrap;}
.susume-time-chip{font-size:11px;padding:2px 7px;border-radius:99px;background:#FFF8E7;color:#8A6800;border:0.5px solid #F0D080;font-weight:500;}
.susume-ep-chip{font-size:11px;padding:2px 7px;border-radius:99px;background:var(--bg2);color:var(--text3);}
.susume-current-badge{font-size:11px;color:var(--blue);}
.susume-empty{padding:14px;text-align:center;font-size:13px;color:var(--text3);}
.time-slider-wrap{margin-bottom:16px;}
.time-slider-labels{display:flex;justify-content:space-between;margin-bottom:6px;}
.time-slider-label{font-size:11px;color:var(--text3);}
.time-slider-track{position:relative;height:36px;display:flex;align-items:center;}
.time-slider-rail{position:absolute;left:0;right:0;height:4px;background:var(--bg3);border-radius:99px;}
.time-slider-range{position:absolute;height:4px;background:#1a1a2e;border-radius:99px;}
.time-slider-thumb{position:absolute;width:24px;height:24px;border-radius:50%;background:#1a1a2e;border:3px solid #fff;box-shadow:0 1px 6px rgba(0,0,0,.25);cursor:pointer;transform:translateX(-50%);touch-action:none;z-index:2;}
.time-slider-selected{margin-top:8px;text-align:center;font-size:13px;font-weight:600;color:#1a1a2e;}
.fb-section{margin-bottom:16px;}
.fb-stars{display:flex;gap:6px;margin-bottom:10px;}
.fb-star{font-size:28px;cursor:pointer;color:var(--border2);transition:color .1s;line-height:1;}
.fb-star.on{color:#F5C518;}
.fb-tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px;}
.fb-tag{font-size:12px;padding:5px 10px;border-radius:99px;border:0.5px solid var(--border);background:var(--bg2);color:var(--text2);cursor:pointer;}
.fb-tag.on-good{background:#E1F5EE;border-color:#1D9E75;color:#0F6E56;font-weight:500;}
.fb-tag.on-bad{background:#FEE9E9;border-color:#E24B4A;color:#C0392B;font-weight:500;}
.fb-send-btn{width:100%;padding:11px;border-radius:var(--r-lg);background:#5865F2;color:#fff;font-size:14px;font-weight:600;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;}
.fb-send-btn:disabled{background:var(--border2);cursor:default;}
.fb-sent{text-align:center;font-size:13px;color:var(--green);padding:8px 0;}
</style>
</head>
<body>
<div class="phone-frame">
<div id="app">
  <div id="map"></div>
  <div class="toast" id="toast"></div>
  <div class="top-ui">
    <div class="search-row">
      <div class="search-pill"><i class="ti ti-map-pin"></i><input type="text" id="placeSearch" placeholder="Search places" oninput="applyFilter()"/></div>
      <div class="anime-pill-wrap" id="animeWrap">
        <div class="anime-pill" id="animePill" onclick="toggleDD(event)">
          <i class="ti ti-movie"></i><span class="anime-pill-label" id="pillLabel">Select Anime</span><i class="ti ti-chevron-down chev"></i>
        </div>
        <div class="anime-dd" id="animeDD">
          <div class="dd-search-row"><input type="text" id="ddInput" placeholder="Search anime..." oninput="renderDDItems(this.value)"/></div>
          <div class="dd-all" onclick="selectAnime('')">All Anime</div>
          <div id="ddItems"></div>
        </div>
      </div>
      <button class="icon-btn" id="locBtn" onclick="getLocation()"><i class="ti ti-current-location"></i></button>
    </div>
    <div id="pilControls" style="display:none;">
      <div class="pil-banner visible" id="pilBanner">
        <span class="pil-banner-text" id="pilBannerText">Click pins to set order</span>
        <button class="pil-exit-btn" onclick="exitPilMode()">Exit</button>
      </div>
    </div>
  </div>
  <div id="locBanner" class="loc-banner"><i class="ti ti-info-circle"></i><span id="locMsg"></span></div>
  <div class="pil-hud" id="pilHud"><div class="pil-next-card" id="pilNextCard"></div></div>
  <div class="bottom-sheet" id="listSheet">
    <div class="sheet-handle-row" onclick="toggleSheet()"><div class="sheet-handle"></div></div>
    <div class="sheet-header">
      <span class="sheet-title" id="sheetTitle">Spot List</span>
      <div style="display:flex;align-items:center;gap:8px;">
        <span class="sheet-count" id="sheetCount">0 spots</span>
        <button class="pil-start-btn" id="pilStartBtn" onclick="startPilgrimage()" disabled style="display:none;"><i class="ti ti-route"></i>Start</button>
      </div>
    </div>
    <div class="sheet-content collapsed" id="sheetContent" style="max-height:50vh;overflow-y:auto;"></div>
  </div>
  <div class="wizard-modal-overlay" id="wizardOverlay" onclick="onWizardOverlayClick(event)">
    <div class="wizard-modal">
      <div class="wizard-modal-handle-row"><div class="wizard-modal-handle"></div></div>
      <div class="wizard-modal-header">
        <span class="wizard-modal-title" id="wizardTitle">Pilgrimage Guide</span>
        <button class="wizard-modal-close" onclick="closeWizardModal()">&#x2715;</button>
      </div>
      <div class="wizard-modal-body" id="wizardModalBody"></div>
    </div>
  </div>
  <div class="detail-overlay" id="detailOverlay" onclick="closeDetail()"></div>
  <div class="detail-sheet" id="detailSheet">
    <button class="detail-close" onclick="closeDetail()"><i class="ti ti-x"></i></button>
    <div class="detail-handle-row"><div class="detail-handle"></div></div>
    <div class="detail-scroll" id="detailScroll"></div>
    <div class="nav-row"><div class="nav-row-inner" id="navRowInner"></div></div>
  </div>
</div>
</div>
