    { place:'Nakabashi Bridge', lat:36.1470, lng:137.2598, episode:'Scenery Scenes', time:'Morning', desc:"One of Takayama's most recognizable landmarks. The red bridge and surrounding river scenery create a peaceful atmosphere similar to the anime.", access:'About 15 minutes on foot from Takayama Station' },
    { place:'Kajibashi Bridge', lat:36.1452, lng:137.2584, episode:'Walking Scenes', time:'Night', desc:'A quieter bridge area often associated with the reflective mood of Hyouka. Nighttime visits provide a particularly calm experience.', access:'About 11 minutes on foot from Takayama Station' },
    { place:'Takayama Jinya', lat:36.1457, lng:137.2570, episode:'Background Scenes', time:'Noon', desc:'A historic government building near several recognizable Hyouka scenery locations. A great stop for fans interested in traditional Japanese architecture.', access:'About 8 minutes on foot from Takayama Station' },
